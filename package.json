    "url": "https://github.com/dannycreations/Baratie.git"
  },
  "homepage": "https://github.com/dannycreations/Baratie",
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "valibot": "^1.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "npm-check-updates": "^22.2.7",
    "prettier": "^3.8.4",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
