  "author": "dannycreations",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "GPL",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "check": "tsc --noEmit",
